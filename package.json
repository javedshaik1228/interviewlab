{
  "name": "interviewlab",
  "version": "0.1.0",
  "description": "A self-hosted system-design and coding interview practice studio.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javedshaik1228/interviewlab.git"
  },
  "bugs": {
    "url": "https://github.com/javedshaik1228/interviewlab/issues"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:pages": "vite --config vite.pages.config.ts",
    "dev:proxy": "wrangler --config wrangler.jsonc dev",
    "build": "npm run typecheck && next build --webpack",
    "build:pages": "vite build --config vite.pages.config.ts",
    "build:proxy": "wrangler --config wrangler.jsonc deploy --dry-run --outdir dist-proxy",
    "start": "next start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern dist-pages --ignore-pattern dist-proxy --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "validate:pages-env": "node scripts/validate-pages-env.mjs",
    "deploy:proxy": "wrangler --config wrangler.jsonc deploy"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "lodash-es@<=4.17.23": "4.18.1",
    "nanoid@<3.3.8": "3.3.16",
    "nanoid@>=4.0.0 <5.0.9": "5.1.16",
    "postcss@<8.5.10": "8.5.19"
  },
  "type": "module"
}

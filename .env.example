# Public origin used for canonical and social-preview URLs.
SITE_URL=http://localhost:3000

# Host port exposed by Docker Compose.
PORT=3000

# Comma-separated browser origins allowed to call /api/interviewer.
# Required when the static frontend and proxy use different origins.
ALLOWED_ORIGINS=http://localhost:5173

# Public proxy origin embedded in a static GitHub Pages build.
NEXT_PUBLIC_INTERVIEWER_API_URL=https://interviewlab-provider-proxy.example.workers.dev
